### 1. Review & Rating System
# Goal: Ensure only enrolled students can review the course
# Note: Replace STUDENT_TOKEN with a valid token for an enrolled student.
POST {{base_url}}/api/courses/4/reviews/
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
    "rating": 5,
    "comment": "This course is amazing! Highly recommended."
}

### 2. Advanced Search & Filtering
# Goal: Test search by category and price range
GET {{base_url}}/api/public/courses/?category=Programming&min_price=50
Accept: application/json

### 3. Stripe Checkout (Simulated)
# Goal: Create a checkout session (returns a URL)
POST {{base_url}}/api/payments/create-checkout-session/
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
    "course_id": 1
}

### 4. Stripe Webhook (Local Simulation)
# Goal: Simulate payment success to trigger automated enrollment
# NOTE: Run this in terminal: stripe trigger checkout.session.completed
# Or use tool: stripe trigger checkout.session.completed

### 5. Course Stats & Dashboard
# Goal: Verify average rating and total enrollments
GET {{base_url}}/api/public/courses/4/
Accept: application/json

### 6. Instructor Revenue API
# Goal: Instructor viewing course revenue
GET {{base_url}}/api/courses/4/revenue/
Authorization: Bearer {{instructor_token}}
Accept: application/json
