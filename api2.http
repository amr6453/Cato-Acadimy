@baseUrl = http://127.0.0.1:8000/api
@token = YOUR_ACCESS_TOKEN_HERE

### 1. Create a Section (Flat Endpoint)
# This uses the user provided curl logic: POST /api/sections/
POST {{baseUrl}}/sections/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzczNDQ2MjM1LCJpYXQiOjE3NzM0NDI2MzUsImp0aSI6ImU3ZjRmYmUxZTUwOTQxNzBhMDJlM2RjMjdjZDg2MDQ5IiwidXNlcl9pZCI6IjEifQ.uoV4om-S1fBukhyvt8UJUI-VF7UhQE0aF3adFZEMoIU
Content-Type: application/json

{
    "course": 1,
    "title": "Chapter 1: Getting Started",
    "order": 1
}

### 2. Create a Lesson (Flat Endpoint)
# This uses the user provided curl logic: POST /api/lessons/
# Note: Use multipart/form-data for file uploads
POST {{baseUrl}}/lessons/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzczNDQ2MjM1LCJpYXQiOjE3NzM0NDI2MzUsImp0aSI6ImU3ZjRmYmUxZTUwOTQxNzBhMDJlM2RjMjdjZDg2MDQ5IiwidXNlcl9pZCI6IjEifQ.uoV4om-S1fBukhyvt8UJUI-VF7UhQE0aF3adFZEMoIU
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="section"

1
--boundary
Content-Disposition: form-data; name="title"

Introduction Video
--boundary
Content-Disposition: form-data; name="lesson_type"

video
--boundary
Content-Disposition: form-data; name="video_file"; filename="sample.mp4"
Content-Type: video/mp4

< ./sample.mp4
--boundary--

### 3. Get Course Details (Deeply Nested)
# This shows Course -> Sections -> Lessons in one request
GET {{baseUrl}}/courses/1/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzczNDQ2MjM1LCJpYXQiOjE3NzM0NDI2MzUsImp0aSI6ImU3ZjRmYmUxZTUwOTQxNzBhMDJlM2RjMjdjZDg2MDQ5IiwidXNlcl9pZCI6IjEifQ.uoV4om-S1fBukhyvt8UJUI-VF7UhQE0aF3adFZEMoIU

### ---------------------------------------------------------
### Nested API Versions (Optional/Advanced)
### ---------------------------------------------------------

### 4. Create Section (Nested)
POST {{baseUrl}}/courses/1/sections/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzczNDQ2MjM1LCJpYXQiOjE3NzM0NDI2MzUsImp0aSI6ImU3ZjRmYmUxZTUwOTQxNzBhMDJlM2RjMjdjZDg2MDQ5IiwidXNlcl9pZCI6IjEifQ.uoV4om-S1fBukhyvt8UJUI-VF7UhQE0aF3adFZEMoIU
Content-Type: application/json

{
    "title": "Nested Section Example"
}

### 5. Create Lesson (Nested)
POST {{baseUrl}}/sections/1/lessons/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzczNDQ2MjM1LCJpYXQiOjE3NzM0NDI2MzUsImp0aSI6ImU3ZjRmYmUxZTUwOTQxNzBhMDJlM2RjMjdjZDg2MDQ5IiwidXNlcl9pZCI6IjEifQ.uoV4om-S1fBukhyvt8UJUI-VF7UhQE0aF3adFZEMoIU
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="title"

Nested Lesson Example
--boundary
Content-Disposition: form-data; name="lesson_type"

TEXT
--boundary
Content-Disposition: form-data; name="content_text"

This lesson was created via a nested endpoint.
--boundary--
